# F5 Predictor Environment Variables
# Copy to .env and fill in your keys

# ── Required ──────────────────────────────────────────────────────
# The Odds API (https://the-odds-api.com)
# Free tier: 500 requests/month
ODDS_API_KEY=your_key_here

# ── Optional: Claude AI Analysis (Phase 10) ──────────────────────
# Anthropic API (https://console.anthropic.com)
# Used for AI-powered prediction analysis (~$0.01-0.05/day)
ANTHROPIC_API_KEY=

# ── Optional: Telegram Notifications ────────────────────────────
# 1. Message @BotFather on Telegram → /newbot → copy token
# 2. Start chat with your bot, then visit:
#    https://api.telegram.org/bot<TOKEN>/getUpdates
#    Copy the "id" value under "chat"
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Free APIs (no keys required) ─────────────────────────────────
# MLB Stats API — free, no auth
# Statcast via pybaseball — free, no auth
# Open-Meteo weather — free, no auth
